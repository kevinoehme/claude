# Beispiel-Env für /etc/claude-secrets/briefing-trigger.env
# Werte ausfüllen, dann nach /etc/claude-secrets/briefing-trigger.env kopieren:
#   sudo install -d -m 0750 -o root -g claude /etc/claude-secrets
#   sudo install -m 0640 -o root -g claude briefing-trigger.env.example /etc/claude-secrets/briefing-trigger.env
#
# WICHTIG: ANTHROPIC_API_KEY MUSS gesetzt sein, sonst meldet `claude -p` "Not logged in".
# Den aktuellen Wert holst du dir per:  grep ANTHROPIC_API_KEY ~/.bashrc

# --- Claude CLI Auth (Pflicht!) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- MQTT-Broker (Werte stehen in /home/claude/.claude.json unter mcpServers.mqtt_notify.env) ---
MQTT_HOST=192.168.8.222
MQTT_PORT=1883
MQTT_USER=homeassistant
MQTT_PASSWORD=
# MQTT_TLS=1
# BRIEFING_TRIGGER_TOPIC=claude/briefing/kamen/request
# BRIEFING_TIMEOUT=180
